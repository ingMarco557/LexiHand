<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:id="@+id/cardStats"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RENDIMIENTO DE IA"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precisión promedio del modelo actual"
            android:textColor="#666666"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtGlobalAccuracy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="94.8%"
                    android:textSize="48sp"
                    android:textColor="#6200EE"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score de Confianza Global"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precisión por Categoría"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Letra 'A'"/>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="98"
            app:trackThickness="8dp"
            app:trackCornerRadius="4dp"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Letra 'B'"/>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="85"
            app:indicatorColor="#FF9800"
            app:trackThickness="8dp"
            app:trackCornerRadius="4dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>