<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_result_game2">

    <ImageView
        android:id="@+id/iv_icon_game2"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="60dp"
        android:src="@android:drawable/ic_menu_edit"
        app:tint="#F8BBD0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_rules_title_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reglas del Juego"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/iv_icon_game2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#40FFFFFF"
        app:cardBackgroundColor="#20FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tv_rules_title_2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Se te mostrará una serie de imágenes en Lengua de Señas. Deberás descifrar la palabra y escribirla antes de que se acaben los 10 segundos.\n\nVeamos de qué estás hecho..."
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textAlignment="center"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btn_start_game2"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="¡Aceptar el reto!"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#D81B60"
        android:backgroundTint="#FFFFFF"
        app:cornerRadius="32dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>