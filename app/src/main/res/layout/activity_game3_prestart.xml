<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:padding="24dp" android:background="#E0F2F1">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Reglas del Juego:" android:textSize="28sp" android:textStyle="bold" android:layout_marginBottom="16dp" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Conecta tu guante. Se mostrará una imagen y tendrás 10 segundos para hacer la seña correcta. Nuestra IA evaluará tu precisión."
        android:textSize="18sp" android:textAlignment="center" android:layout_marginBottom="32dp" />

    <Button android:id="@+id/btn_start_game3" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="Conectar Guante e Iniciar" android:textSize="20sp" android:backgroundTint="#00BFA5" />
</LinearLayout>