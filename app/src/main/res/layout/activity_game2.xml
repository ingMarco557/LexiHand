<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal"
    android:background="#F3F3F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tv_game2_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1/10"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"/>

        <TextView
            android:id="@+id/tv_game2_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Escríbelo en ⏱️ 10"
            android:textSize="22sp"
            android:textColor="@android:color/holo_red_dark"
            android:textStyle="bold" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginBottom="32dp"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layout_word_images"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
        </LinearLayout>

    </HorizontalScrollView>

    <EditText
        android:id="@+id/et_user_answer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Escribe la palabra aquí..."
        android:inputType="textCapCharacters"
        android:gravity="center"
        android:textSize="20sp"
        android:textColor="@android:color/black"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_submit_answer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Comprobar"
        android:textSize="18sp"
        android:backgroundTint="#FF4081"/>

</LinearLayout>