<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_result_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1/10"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱️ 10s"
            android:textSize="24sp"
            android:textColor="#FF5252"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_sign_image"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginBottom="40dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_launcher_background" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_1"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="12dp"
        android:textSize="18sp"
        android:text="A"
        android:textColor="#FFFFFF"
        app:backgroundTint="#33FFFFFF"
        app:cornerRadius="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_2"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="12dp"
        android:textSize="18sp"
        android:text="B"
        android:textColor="#FFFFFF"
        app:backgroundTint="#33FFFFFF"
        app:cornerRadius="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_3"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="12dp"
        android:textSize="18sp"
        android:text="C"
        android:textColor="#FFFFFF"
        app:backgroundTint="#33FFFFFF"
        app:cornerRadius="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_option_4"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:textSize="18sp"
        android:text="D"
        android:textColor="#FFFFFF"
        app:backgroundTint="#33FFFFFF"
        app:cornerRadius="16dp"/>

</LinearLayout>