<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingTop="32dp"
    android:paddingHorizontal="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resumen"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="#111111"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#EAEAEA"
        app:cardBackgroundColor="#FAFAFB">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="24dp"
            android:paddingHorizontal="16dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 Mi Racha"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/txtRachaHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B00"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#EAEAEA"
                android:layout_marginHorizontal="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Precisión"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/txtPrecisionHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#3618C3"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dispositivo"
        android:layout_marginTop="32dp"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#111111"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVincularGuante"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:text="Vincular Guante LexiHand"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="20dp"
        app:icon="@android:drawable/stat_sys_data_bluetooth"
        app:iconGravity="textStart"
        app:iconSize="24dp"
        app:backgroundTint="#5A22E1"
        android:textColor="#FFFFFF"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Actividad Reciente"
        android:layout_marginTop="32dp"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#111111"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F5F6FA">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Aún no hay actividad reciente."
            android:textAlignment="center"
            android:textStyle="italic"
            android:textColor="#A0A0A0"
            android:textSize="14sp"/>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>