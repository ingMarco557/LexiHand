<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FA"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Racha"
                    android:textSize="14sp"
                    android:textColor="#757575"/>
                <TextView
                    android:id="@+id/txtRachaHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 🔥"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FF5722"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="50dp"
                android:background="#EEEEEE"
                android:layout_marginHorizontal="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Precisión"
                    android:textSize="14sp"
                    android:textColor="#757575"/>
                <TextView
                    android:id="@+id/txtPrecisionHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% 🎯"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1A73E8"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dispositivo"
        android:layout_marginTop="24dp"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#212121"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVincularGuante"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:text="Vincular Guante LexiHand"
        android:textSize="16sp"
        app:cornerRadius="15dp"
        app:icon="@android:drawable/stat_sys_data_bluetooth"
        app:iconGravity="textStart"
        android:backgroundTint="#1A73E8"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Actividad Reciente"
        android:layout_marginTop="24dp"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#212121"/>

</LinearLayout>