<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarCollection"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:title="Recolección de Datos (ML)"
            app:navigationIcon="@drawable/ic_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gesto a Entrenar:"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerGestures"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutCustomGesture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del gesto personalizado"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCustomGesture"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapCharacters" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/txtSampleCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Muestras: 0 / 100"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressSamples"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progress="0"
                app:trackThickness="12dp"
                app:trackCornerRadius="6dp"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monitor del Guante:"
                        android:textColor="#00FF00"
                        android:fontFamily="monospace"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/txtRealTimeData"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Esperando conexión..."
                        android:textColor="#00FF00"
                        android:fontFamily="monospace"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2">

                <Button
                    android:id="@+id/btnStartStop"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="Grabar"
                    android:backgroundTint="#4CAF50"/>

                <Button
                    android:id="@+id/btnExport"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="Subir a Nube"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <Button
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_columnWeight="2"
                    android:layout_margin="4dp"
                    android:text="Limpiar Muestras Locales"
                    android:backgroundTint="#F44336"
                    style="@style/Widget.Material3.Button.TonalButton"/>
            </GridLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#E3F2FD"
                app:cardCornerRadius="12dp"
                app:strokeColor="#2196F3"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sincronizado con Firebase:"
                        android:textColor="#1565C0"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/txtGestosNube"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Consultando..."
                        android:textColor="#0D47A1"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>
                    <Button
                        android:id="@+id/btnDownloadModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Descargar Modelo AI"
                        app:icon="@android:drawable/stat_sys_download"
                        android:backgroundTint="#2196F3"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>