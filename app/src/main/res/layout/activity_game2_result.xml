<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFEAEE">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultados Descifrado"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />


    <TextView
        android:id="@+id/tv_racha_final"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Racha: 0 🔥"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FF9800"
        android:layout_marginTop="16dp"/>


    <TextView
        android:id="@+id/tv_game2_score_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descifraste 3 de 4"
        android:textSize="20sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_game2_percentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="75%"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FF4081"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btn_game2_finish"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Volver al Arcade"
        android:backgroundTint="#FF4081"
        android:textSize="18sp" />
</LinearLayout>